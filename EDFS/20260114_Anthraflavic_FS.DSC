begin exp2 "Nutation for Delta F vs Mz" [INTG QUAD]\n\
\n\
 totscans(n)                   ; output of total number of scans\n\
p13=p0                         ; store d1\n\
af6=af4                        ; store awg amplitude\n\
af7=af5                        ; store awg amplitude\n\
 for k=1 to n                  ; averaging loop\n\
 pg=200                        ; integration gate, standard 200 ns\n\
totscans(n)                    ; output of total number of scans\n\
 af4=af6                       ; reset awg amplitude\n\
 af5=af7                       ; reset awg amplitude\n\
 dx=af6-af7                    ; reset initial dy to aa1\n\
 p0=p13                        ; reset initial nutation pulse length\n\
      sweep x=1 to sx          ; sweep loop\n\
       shot i=1 to h           ; accumulation loop\n\
\n\
         d9                    ; DAF\n\
         p3 [awg3]             ; 1st observer pulse (pi/2) and phase program\n\
         d1                    ; tau1\n\
         p1 [awg1]             ; 2nd observer pulse (pi) and phase program\n\
         d2                    ; pump pulse delay, initially deadtime\n\
         p2 [awg0]             ; pump pulse (pi)\n\
         d2\n\
         d0                    ; acqusition delay\n\
         acq [sg1]             ; acquisition\n\
       next i                  ; end of accumulation loop\n\
     dx=dx+1000                 ; define time axis increment d30 = 2\n\
     af4=af4-1000               ; increment pump pulse delay\n\
     af5=af5+1000               ; increment pump pulse delay\n\
      next x                   ; end of sweep loop\n\
   scansdone(k)                ; output of scans done  \n\
 next k                        ; end of scan accumulation loop \n\
end exp2\n\
\n\
begin exp3 "Nutation for Offset vs Mz" [INTG QUAD]\n\
\n\
 totscans(n)                   ; output of total number of scans\n\
p13=p0                         ; store d1\n\
af8=af6                        ; store awg amplitude\n\
af9=af7                        ; store awg amplitude\n\
af18=af9-af8                    ; reset initial dy to aa1\n\
af18=af18/2\n\
 for k=1 to n                  ; averaging loop\n\
 pg=200                        ; integration gate, standard 200 ns\n\
totscans(n)                    ; output of total number of scans\n\
 af6=af8                       ; reset awg amplitude\n\
 af7=af9                       ; reset awg amplitude\n\
dx=af18+af6\n\
 p0=p13                        ; reset initial nutation pulse length\n\
      sweep x=1 to sx          ; sweep loop\n\
       shot i=1 to h           ; accumulation loop\n\
\n\
         d9                    ; DAF\n\
         p3 [awg4]             ; 1st observer pulse (pi/2) and phase program\n\
         d1                    ; tau1\n\
         p1 [awg1]             ; 2nd observer pulse (pi) and phase program\n\
         d2                    ; pump pulse delay, initially deadtime\n\
         p2 [awg0]             ; pump pulse (pi)\n\
         d2\n\
         d0                    ; acqusition delay\n\
         acq [sg1]             ; acquisition\n\
       next i                  ; end of accumulation loop\n\
\n\
     dx=dx+1000                 ; define time axis increment d30 = 2\n\
     af6=af6+1000               ; increment pump pulse delay\n\
     af7=af7+1000               ; increment pump pulse delay\n\
      next x                   ; end of sweep loop\n\
   scansdone(k)                ; output of scans done  \n\
 next k                        ; end of scan accumulation loop \n\
end exp3\n\
\n\
begin exp4 "Nutation vs B0" [INTG QUAD]\n\
\n\
 totscans(n)                   ; output of total number of scans\n\
p13=p0                         ; initial delay between second observer\n\
d13=d1\n\
for k=1 to n                   ; averaging loop\n\
bsweep y=1 to sy               ; B0 sweep\n\
 pg=200;                       ; integration gate, standard 200 ns\n\
 p13=p0                        ; initial delay between second observer\n\
                               ; pulse and pump pulse\n\
      p0=p13                   ; reset initial pump pulse delay\n\
      d1=d13                   ;reset initial pump pulse delay\n\
      sweep x=1 to sx          ; sweep loop\n\
\n\
       shot i=1 to h           ; accumulation loop\n\
\n\
         d9                    ; DAF\n\
         p0 [awg0]             ; 1st observer pulse (pi/2) and phase program\n\
         d1                    ; tau1\n\
         p1 [awg1]             ; 2nd observer pulse (pi) and phase program\n\
         d2                    ; pump pulse delay, initially deadtime\n\
         p2 [awg0]             ; pump pulse (pi)\n\
         d2\n\
         d0                    ; acqusition delay\n\
         acq [sg1]             ; acquisition\n\
       next i                  ; end of accumulation loop\n\
\n\
       dx=dx+d30               ; define time axis increment d30 = 2\n\
       p0=p0+d30               ; increment pump pulse delay\n\
       d1=d1+d30               ; also step d1 with the length increment\n\
       	    \n\
      next x                   ; end of sweep loop  \n\
      next y                   ; end of sweep loop  \n\
   scansdone(k)                ; output of scans done  \n\
 next k                        ; end of scan accumulation loop \n\
end exp4\n\
\n
