PlsSPELGlbTxt      \
;     PulseSPEL variables for DEER experiments\n\
;\n\
begin defs\n\
;                                               \n\
;\n\
;optimized for home-made Q band F238, May2010, attention! pulse lengths can be different\n\
;Gunnar Jeschke 2002, Polyhach-Bordignon 2010, Bordignon for Qband commercial TWT ser. number 17 2011\n\
; Repetition time\n\
;Teucher-Assafa-Bordignon 2016: Gaussian Pulses, 16-step phase cycle\n\
;\n\
srt  = 3000 * srtu ; shot repetition time, srtu= 1 us\n\
;                 ; usual values for nitroxides: 1000 * srtu at 80 K\n\
                   ; 4000 * srtu at 50 K\n\
;                  ; 10000...40000 * srtu at 15 K\n\
;\n\
; Pulse lengths\n\
;                        \n\
p0   = 0       ; observer pi pulse length (frq1), 12 ns for hard pulses\n\
p1   = 17      ; observer pi/2 pulse length (frq1), 12 ns for hard pulses\n\
p2   = 34      ; pump pi pulse length (frq2), 12 ns for hard pulses\n\
p3   = 250     ; \n\
;\n\
; Variable delays\n\
; \n\
d0   = 440     ; optimized for commercial Q band TWT ser.nr. 17 20 Mhz bandwidth\n\
d1   = 1000    ; tau1 (initial value)\n\
d2   = 400     ; tau2\n\
\n\
; Time increments\n\
;\n\
d30  = 2       ; t time scale increment of \n\
d31  = 2     ; amplitude increment\n\
; Counters\n\
;\n\
h    = 4      ; number of shots/loop                     ( counter: I )\n\
n    = 1       ; number of sweeps to accumulate           ( counter: K )\n\
;\n\
; ### Block of additional variables (Bruker definitions) ###\n\
;p3   = 40      ;\n\
p7   = 80      ; LeCroy trigger\n\
p9   = 1000    \n\
pg   = 200     ; Integrator Gate Width (is superseeded by DEER pulse program)\n\
;\n\
;\n\
d4   = 1       ;\n\
d5   = 400     ;\n\
                        ;\n\
dx   = 0       ; t time scale starting value\n\
dy   = 0       ; t1 time scale starting value\n\
               ;\n\
\n\
d20  = 0       ; Initial value of dx\n\
d21  = 0       ; Initial value of dy\n\
                        ;\n\
s    = 300     ; Sweep length (n. of data really taken)   ( counter: X )\n\
t    = 1       ; second time axsis sweep length           ( counter: Y )\n\
               ;\n\
r    = 1       ;\n\
c    = 1       ;\n\
b    = 1       ;\n\
             ;\n\
w    = 180     ; Split point of sweeps (ns) ,i.e. pulse separation where\n\
             ; TWT gate pulse can be split.\n\
;\n\
d6   = 100 us  \n\
; VARIABLES for AWG\n\
\n\
; observe pulse variables\n\
; pi/2 pulse (awg0), observer\n\
af0  = 0       ; start frequency / Hz\n\
af1  = 0       ; end frequency / Hz\n\
aa0  = 100     ; amplitude / %\n\
as0  = 0       ; shape\n\
\n\
; pi pulse (awg1), observer\n\
af2  = 0       ; start frequency / Hz\n\
af3  = 0       ; end frequency / Hz\n\
aa1  = 10      ; amplitude / %\n\
as1  = 0       ; shape\n\
\n\
; pi pulse (awg2), chirp pulse for Nutation vs DF\n\
af4  = 0       ; start frequency / Hz\n\
af5  = 0       ; end frequency / Hz\n\
aa2  = 10      ; amplitude / %\n\
as2  = 5       ; shape\n\
\n\
; pi pulse (awg4), chirp pulse for Nutation vs Offset\n\
af6  = -275000 ; start frequency / Hz\n\
af7  = -125000 ; end frequency / Hz\n\
aa3  = 5       ; amplitude / %\n\
as3  = 5       ; shape\n\
\n\
\n\
ap0  = 0       ; phase units in degrees\n\
ap1  = 0       ; phase units in degrees\n\
\n\
da1  = 1       ; AWG steps in this case the phase steps\n\
\n\
; end of AWG variables  \n\
end defs\n\
\n
PlsSPELLISTSlct    2-step phase cycling
PlsSPELPhPrgEx     Normal
PlsSPELPrg         PulseSPEL/Q_Band_Nutation_awg.exp
PlsSPELPrgTxt      \
begin defs\n\
dim s[400]                      ;     dimension of data trace [sx] for nutation\n\
dim1 s[400,46]                 ;     dimension of data trace [sx,sy] for nutation vs amplitude\n\
dim2 s[400]                 ;     dimension of data trace [sx] for Mz vs Delta F\n\
dim3 s[400]                 ;     dimension of data trace [sx] for Mz vs Offset\n\
dim4 s[200,200]                 ;     dimension of data trace [sx,sy] for Nutation vs B0\n\
end defs\n\
\n\
begin lists "no phase cycling"	; \n\
 asg1 +a \n\
 bsg1 +b \n\
end lists\n\
\n\
begin lists1 "2-step phase cycling"	; This phase cycle removes all echoes except the refocused echo in DEER\n\
 asg1 +a -a \n\
 bsg1 +b -b\n\
end lists1\n\
\n\
begin awg0 ; This is the pi pulse\n\
	af0		; start frequency [MHz]\n\
	af1		; end frequency [MHz]\n\
	0		; phase [degrees]\n\
	aa0		; amplitude [%]\n\
	as0		; shape\n\
end awg0\n\
\n\
begin awg1 ; This is the pi/2 pulse with 2-step phase cycling\n\
	af0	af0		; start frequency [Hz]\n\
	af1	af1		; end frequency [Hz]\n\
	0	180		; phase [degrees]\n\
	aa0	aa0		; amplitude [%],  see variables, optimized !!\n\
	as0	as0		; shape\n\
end awg1\n\
\n\
begin awg2 ; This is the first pulse\n\
	af0	; start frequency [MHz]\n\
	af1	; end frequency [MHz]\n\
	0 	; phase [degrees] % to be optimized\n\
	aa1	; amplitude [%], see variables\n\
	as0	; shape\n\
end awg2\n\
\n\
begin awg3 ; This is the first pulse\n\
	af4	; start frequency [MHz]\n\
	af5	; end frequency [MHz]\n\
	0 	; phase [degrees] % to be optimized\n\
	aa2	; amplitude [%], see variables\n\
	as2	; shape\n\
end awg3\n\
\n\
begin awg4 ; This is the first pulse\n\
	af6	; start frequency [MHz]\n\
	af7	; end frequency [MHz]\n\
	0 	; phase [degrees] % to be optimized\n\
	aa3	; amplitude [%], see variables\n\
	as3	; shape\n\
end awg4\n\
\n\
begin exp "Nutation experiment with phase cycling" [INTG QUAD]\n\
\n\
 totscans(n)                   ; output of total number of scans\n\
p13=p0                         ; initial delay between second observer\n\
d13=d1\n\
for k=1 to n                   ; averaging loop\n\
 pg=200;                        ; integration gate, standard 200 ns\n\
 p13=p0                        ; initial delay between second observer\n\
                               ; pulse and pump pulse\n\
      p0=p13                   ; reset initial pump pulse delay\n\
      d1=d13                   ;reset initial pump pulse delay\n\
      sweep x=1 to sx          ; sweep loop\n\
\n\
       shot i=1 to h           ; accumulation loop\n\
\n\
         d9                    ; DAF\n\
         p0 [awg2]              ; 1st observer pulse (pi/2) and phase program\n\
         d1                    ; tau1\n\
         p1 [awg1]              ; 2nd observer pulse (pi) and phase program\n\
         d2                    ; pump pulse delay, initially deadtime\n\
         p2 [awg0]              ; pump pulse (pi)\n\
         d2\n\
         d0                    ; acqusition delay\n\
         acq [sg1]             ; acquisition\n\
       next i                  ; end of accumulation loop\n\
\n\
       dx=dx+d30               ; define time axis increment d30 = 2\n\
       p0=p0+d30               ; increment pump pulse delay\n\
       d1=d1+d30               ; also step d1 with the length increment\n\
       	    \n\
      next x                   ; end of sweep loop  \n\
      			\n\
   scansdone(k)                ; output of scans done  \n\
 next k                        ; end of scan accumulation loop \n\
end exp\n\
\n\
begin exp1 "Nutation for B1 vs AWG amplitude" [INTG QUAD]\n\
\n\
 totscans(n)                   ; output of total number of scans\n\
p13=p0                         ; store d1\n\
aa2=aa1                        ; store awg amplitude\n\
 for k=1 to n                  ; averaging loop\n\
 pg=200                        ; integration gate, standard 200 ns\n\
\n\
 aa1=aa2                       ; reset awg amplitude\n\
 dy=aa1                        ; reset initial dy to aa1\n\
 for y=1 to sy                 ; sweep AWG amplitude\n\
 p0=p13                        ; reset initial nutation pulse length\n\
      sweep x=1 to sx          ; sweep loop\n\
       shot i=1 to h           ; accumulation loop\n\
\n\
         d9                    ; DAF\n\
         p0 [awg2]             ; 1st observer pulse (pi/2) and phase program\n\
         d1                    ; tau1\n\
         p1 [awg1]             ; 2nd observer pulse (pi) and phase program\n\
         d2                    ; pump pulse delay, initially deadtime\n\
         p2 [awg0]             ; pump pulse (pi)\n\
         d2\n\
         d0                    ; acqusition delay\n\
         acq [sg1]             ; acquisition\n\
       next i                  ; end of accumulation loop\n\
\n\
       dx=dx+d30               ; define time axis increment d30 = 2\n\
       p0=p0+d30               ; increment pump pulse delay\n\
       d1=d1+d30               ; also step d1 with the length increment\n\
\n\
      next x                   ; end of sweep loop  \n\
       dy=dy+d31               ; define time axis increment d30 = 2\n\
       aa1=aa1+d31             ; increment AWG amplitude\n\
      next y                   ; end of AWG sweep loop\n\
\n\
   scansdone(k)                ; output of scans done  \n\
 next k                        ; end of scan accumulation loop \n\
end exp1\n\
\n\
