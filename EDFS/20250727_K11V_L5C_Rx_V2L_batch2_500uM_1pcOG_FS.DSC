;\n\
;     Variable definitions for RIDME\n\
;\n\
;     PulseSPEL general variables, definitions & conventions\n\
\n\
begin defs\n\
; Variables    ; Comments:\n\
\n\
p0   = 18      ; AWG 90 pulse length\n\
p1   = 36      ; AWG 180 pulse length\n\
p2   = 9000    ; CIDME pulse length\n\
\n\
pg   = 56      ; Integrator Gate Width (RESERVED)\n\
d0   = 496     ; Detection Trigger offset time\n\
\n\
d1   = 400     ; tau. can change to 3600 for metal metal ridme. then change d3 by the same amount.\n\
d2   = 10000   ; T. SShould be equivalent to CIDME block length\n\
d3   = 280     ; delay before second pi/2. d1-120 to detect before zero time\n\
d5   = 2120    ; delay after third pi/2. time trace length-d3\n\
\n\
d10  = 500     ; T in CIDME, 500 us before and after 9us chirp \n\
d16  = 9500    ; T in CIDME, 500 us before and after 9us chirp \n\
d9   = 0       ; DAF (Delay After Flash) delay pulse sequence until\n\
               ; after external event (eg. laser pulse)\n\
d30  = 8       ; 1st time scale increment\n\
d31  = 10000   ; 2nd time scale increment\n\
d23  = 260000  ; inversion filter time\n\
d24  = 50000   ; inversion filter time increment in 2D exp\n\
m    = 1       ; deuterium modulation averaging steps\n\
d4   = 16      ; deuterium modulation step length in nanoseconds\n\
\n\
a    = 1024    ; (RESERVED) number of transient averages (TRANS)\n\
               ; if greater than 1024, a must be a multiple of 1024\n\
h    = 1       ; (CONVENTION) number of shots per point (INTG and SPT)\n\
n    = 5555    ; (CONVENTION) number of sweeps to accumulate\n\
\n\
srt  = 3000 * srtu ; (RESERVED) SRT - Shot Repetition Time (srtu=1.02 us)\n\
\n\
b    = 1       ;\n\
c    = 1       ;\n\
r    = 1       ;\n\
w    = 800     ; (CONVENTION) Split point of sweeps (points)\n\
               ; i.e. pulse separation where TWT gate pulse can be split.\n\
dx   = 0       ; (RESERVED) 1st time scale starting value\n\
dy   = 0       ; (RESERVED) 2nd time scale starting value\n\
\n\
;VARIABLES for AWG\n\
\n\
; observe pulse variables\n\
; pi/2 pulse (awg0)\n\
af0  = 0       ; start frequency / kHz; offset from mid frequency\n\
af1  = 0       ; end frequency / kHz; same\n\
aa0  = 100     ; amplitude / %; check power\n\
as0  = 0       ; shape\n\
as1  = 0       ; shape\n\
\n\
;pi/2 pulse phases\n\
\n\
ap0  = 180     \n\
ap1  = 0       \n\
ap2  = 90      \n\
ap3  = 270     \n\
\n\
;pi pulse phases\n\
ap4  = 0       \n\
ap5  = 90      \n\
ap6  = 180     \n\
ap7  = 270     \n\
\n\
; CIDME Chirp pulse (awg1) ; 2 to test... +50-+200?, -50-(-150)?\n\
af2  = 50000  ; start frequency / kHz  \n\
af3  = 225000 ; end frequency / kHz\n\
aa1  = 100     ; amplitude / %\n\
as2  = 0       ; shape\n\
\n\
af0  = 0       ; start frequency / kHz\n\
af1  = 0       ; end frequency / kHz\n\
\n\
end defs\n\
\n
PlsSPELLISTSlct    none
PlsSPELPhPrgEx     Normal
PlsSPELPrg         PulseSPEL/Q_Band_CIDME.exp
PlsSPELPrgTxt      \
;\n\
;\n\
;RIDME\n\
;\n\
;Ellen Hayes and Eric Evans\n\
;\n\
;P. Hofer, A. Grupp, G. Nebenfuhr and M. Mehring\n\
;               Chem. Phys. Lett. 1986, v. 132, p. 279\n\
;C. Gemperle, G. Aebli, A. Schweiger, and R. R. Ernst\n\
;                       J. Man. Reson. 1990, v. 88, p. 241\n\
;\n\
begin defs              ;       dimension of data array [sx,sy]\n\
 dim s[130]             ;       5P RIDME collect on RVE\n\
 dim1 s[130,50]       ;       2D 5P RIDME (collect every scan)\n\
 dim2 s[130]            ;       5P RIDME colect on RSE\n\
 dim3 s[130,15]		;	5P RIDME RVE vs Tr\n\
 dim4 s[130,15]		;	5P RIDME RVE vs B0\n\
 dim5 s[130]		;	5P CIDME RVE\n\
end defs\n\
;\n\
;\n\
begin lists "none"\n\
 ph1 +x\n\
 ph2 +x\n\
 ph3 +x\n\
 ph4 +x\n\
 asg1 +a\n\
 bsg1 +b\n\
end lists\n\
\n\
begin lists1 "2-step"\n\
 ph1 +x +x\n\
 ph2 +x +x\n\
 ph3 +x +x\n\
 ph4 +x -x\n\
 asg1 +a -a\n\
 bsg1 +b -a\n\
end lists1\n\
\n\
;begin lists2 "4-step"\n\
; ph1 +x -x +x -x\n\
; ph2 +x +x -x -x \n\
; ph3 +x +x +x +x\n\
; ph4 -x -x -x -x  ; not needed in 3 pulse RIDME\n\
; asg1 +a -a -a +a\n\
; bsg1 +b -b -b +b\n\
;end lists2\n\
\n\
begin lists2 "8-step"\n\
; ph1 +x +x +x +x  -x -x -x -x\n\
; ph2 +x +x -x -x  +x +x -x -x ; does not matter in 5-Pulse RIDME\n\
; ph3 +x -x +x -x  +x -x +x -x\n\
; ph4 +x -x +x -x  +x -x +x -x\n\
 asg1 +a +a +a +a  -a -a -a -a\n\
 bsg1 +b +b +b +b  -b -b -b -b\n\
end lists2\n\
\n\
begin lists3 "32-step"\n\
; ph1 +x +x +x +x  -x -x -x -x\n\
; ph2 +x +x -x -x  +x +x -x -x ; does not matter in 5-Pulse RIDME\n\
; ph3 +x -x +x -x  +x -x +x -x\n\
; ph4 +x -x +x -x  +x -x +x -x\n\
 asg1 +a +a +a +a  -a -a -a -a  +a +a +a +a  -a -a -a -a  +a +a +a +a  -a -a -a -a  +a +a +a +a  -a -a -a -a\n\
 bsg1 +b +b +b +b  -b -b -b -b  +b +b +b +b  -b -b -b -b  +b +b +b +b  -b -b -b -b  +b +b +b +b  -b -b -b -b\n\
end lists3\n\
\n\
begin awg0 ; This is the first pi/2 pulse\n\
	af0	af0	af0	af0	af0	af0	af0	af0; start frequency [MHz]\n\
	af1	af1	af1	af1	af1	af1	af1	af1; end frequency [MHz]\n\
	ap0	ap0	ap0	ap0	ap1	ap1	ap1	ap1; phase [degrees]\n\
	aa0	aa0	aa0	aa0 	aa0	aa0	aa0	aa0; amplitude [%],  see variables, optimized !!\n\
	as0	as0	as0	as0 	as0	as0	as0	as0; shape\n\
end awg0\n\
\n\
begin awg1 ; This is the pi pulse\n\
	af0	af0	af0	af0     af0	af0	af0	af0; start frequency [MHz]\n\
	af1	af1	af1	af1 	af1	af1	af1	af1; end frequency [MHz]\n\
	ap4	ap4	ap4	ap4	ap4	ap4	ap4	ap4; phase [degrees]\n\
	aa1	aa1	aa1	aa1 	aa1	aa1	aa1	aa1; amplitude [%],  see variables, optimized !!\n\
	as1	as1	as1	as1 	as1	as1	as1	as1; shape\n\
end awg1\n\
\n\
begin awg2 ; This is the second and third pi/2 pulse\n\
	af0	af0	af0	af0     af0	af0	af0	af0; start frequency [MHz]\n\
	af1	af1	af1	af1 	af1	af1	af1	af1; end frequency [MHz]\n\
	ap0	ap1	ap2	ap3	ap0	ap1	ap2	ap3; phase [degrees]\n\
	aa0	aa0	aa0	aa0 	aa0	aa0	aa0	aa0; amplitude [%],  see variables, optimized !!\n\
	as0	as0	as0	as0 	as0	as0	as0	as0; shape\n\
end awg2\n\
\n\
begin awg3 ; This is the first pi/2 pulse\n\
	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0	af0; start frequency [MHz]\n\
	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1	af1; end frequency [MHz]\n\
	ap0	ap0	ap0	ap0	ap1	ap1	ap1	ap1	ap0	ap0	ap0	ap0	ap1	ap1	ap1	ap1	ap0	ap0	ap0	ap0	ap1	ap1	ap1	ap1	ap0	ap0	ap0	ap0	ap1	ap1	ap1	ap1; phase [degrees]\n\
	aa0	aa0	aa0	aa0 	aa0	aa0	aa0	aa0	aa0	aa0	aa0	aa0 	aa0	aa0	aa0	aa0	aa0	aa0	aa0	aa0 	aa0	aa0	aa0	aa0	aa0	aa0	aa0	aa0 	aa0	aa0	aa0	aa0; amplitude [%],  see variables, optimized !!\n\
	as0	as0	as0	as0 	as0	as0	as0	as0	as0	as0	as0	as0 	as0	as0	as0	as0	as0	as0	as0	as0 	as0	as0	as0	as0	as0	as0	as0	as0 	as0	as0	as0	as0; shape\n\
end awg3\n\
\n\
begin awg4 ; This is the first and second pi pulse\n\
	af0	af0	af0	af0     af0	af0	af0	af0	af0	af0	af0	af0     af0	af0	af0	af0	af0	af0	af0	af0     af0	af0	af0	af0	af0	af0	af0	af0     af0	af0	af0	af0; start frequency [MHz]\n\
	af1	af1	af1	af1 	af1	af1	af1	af1	af1	af1	af1	af1 	af1	af1	af1	af1	af1	af1	af1	af1 	af1	af1	af1	af1	af1	af1	af1	af1 	af1	af1	af1	af1; end frequency [MHz]\n\
	ap4	ap4	ap4	ap4	ap4	ap4	ap4	ap4  	ap5	ap5	ap5	ap5	ap5	ap5	ap5	ap5	ap6	ap6	ap6	ap6	ap6	ap6	ap6	ap6  	ap7	ap7	ap7	ap7	ap7	ap7	ap7	ap7; phase [degrees]\n\
	aa1	aa1	aa1	aa1 	aa1	aa1	aa1	aa1	aa1	aa1	aa1	aa1 	aa1	aa1	aa1	aa1	aa1	aa1	aa1	aa1 	aa1	aa1	aa1	aa1	aa1	aa1	aa1	aa1 	aa1	aa1	aa1	aa1; amplitude [%],  see variables, optimized !!\n\
	as1	as1	as1	as1 	as1	as1	as1	as1	as1	as1	as1	as1 	as1	as1	as1	as1	as1	as1	as1	as1 	as1	as1	as1	as1	as1	as1	as1	as1 	as1	as1	as1	as1; shape\n\
end awg4\n\
\n\
begin awg5 ; This is the second and third pi/2 pulse\n\
	af0	af0	af0	af0     af0	af0	af0	af0	af0	af0	af0	af0     af0	af0	af0	af0	af0	af0	af0	af0     af0	af0	af0	af0	af0	af0	af0	af0     af0	af0	af0	af0; start frequency [MHz]\n\
	af1	af1	af1	af1 	af1	af1	af1	af1	af1	af1	af1	af1 	af1	af1	af1	af1	af1	af1	af1	af1 	af1	af1	af1	af1	af1	af1	af1	af1 	af1	af1	af1	af1; end frequency [MHz]\n\
	ap0	ap1	ap2	ap3	ap0	ap1	ap2	ap3	ap0	ap1	ap2	ap3	ap0	ap1	ap2	ap3	ap0	ap1	ap2	ap3	ap0	ap1	ap2	ap3	ap0	ap1	ap2	ap3	ap0	ap1	ap2	ap3; phase [degrees]\n\
	aa0	aa0	aa0	aa0 	aa0	aa0	aa0	aa0	aa0	aa0	aa0	aa0 	aa0	aa0	aa0	aa0	aa0	aa0	aa0	aa0 	aa0	aa0	aa0	aa0	aa0	aa0	aa0	aa0 	aa0	aa0	aa0	aa0; amplitude [%],  see variables, optimized !!\n\
	as0	as0	as0	as0 	as0	as0	as0	as0	as0	as0	as0	as0 	as0	as0	as0	as0	as0	as0	as0	as0 	as0	as0	as0	as0	as0	as0	as0	as0 	as0	as0	as0	as0; shape\n\
end awg5\n\
\n\
begin awg6 ; This is the Chirp CIDME pulse\n\
	af2	af2	af2	af2  af2	af2	af2	af2	af2	af2	af2	af2     af2	af2	af2	af2	af2	af2	af2	af2     af2	af2	af2	af2	af2	af2	af2	af2     af2	af2	af2	af2; start frequency [MHz]\n\
	af3	af3	af3	af3 	af3	af3	af3	af3	af3	af3	af3	af3 	af3	af3	af3	af3	af3	af3	af3	af3 	af3	af3	af3	af3	af3	af3	af3	af3 	af3	af3	af3	af3; end frequency [MHz]\n\
	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0	ap0; phase [degrees]\n\
	aa1	aa1	aa1	aa1 	aa1	aa1	aa1	aa1	aa1	aa1	aa1	aa1 	aa1	aa1	aa1	aa1	aa1	aa1	aa1	aa1 	aa1	aa1     aa1	aa1	aa1	aa1	aa1	aa1 	aa1	aa1	aa1	aa1; amplitude [%],  see variables, optimized !!\n\
	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2	as2; shape\n\
end awg6\n\
\n\
begin exp "5P RIDME RVE" [INTG QUAD lists lists2 lists3]\n\
; QUAD detection Single Point - 4-step phase cycle default\n\
\n\
d8 = d3                         ; store initial d3\n\
d7 = d5                         ; store initial d5\n\
d21 = d1                         ; store initial tau1 value\n\
 for k=1 to n                   ; averaging loop\n\
  totscans(n)                   ; output of total number of scans\n\
d8=d3                           ; initial delay between second observer\n\
d7=d5                           ; pulse and pump pulse\n\
d1=d21                          ; initial tau1 value\n\
for j=1 to m                    ; tau1 averaging loop for suppression of\n\
;                                nuclear modulations\n\
  d13 = d8                      ; reset initial d3\n\
  d15 = d7                      ; reset initial d5\n\
  d11 = d15 - d1               ;\n\
  d6 = d11 + d13                ; define d6\n\
  dx = d13 - d1                ; reset initial x\n\
  \n\
  sweep x=1 to sx               ; tau sweep loop\n\
    shot i=1 to h               ; accumulation loop\n\
    d9                          ; DAF (Delay After Flash)\n\
    p0 [awg3]                   ; 1st pulse, pi/2\n\
    d1                          ; tau\n\
    p1 [awg4]                   ; 2nd pulse, pi\n\
    d13                         ; initial delay, 40 ns less than tau\n\
    p0 [awg5]                   ; 3rd pulse, pi/2 and phase program\n\
    d2                          ; Constant time T, ~30us?\n\
    p0 [awg5]                   ; 4th pulse, pi/2\n\
    d15                          ; make longer than total aquisition\n\
    p1 [awg4]                   ; 5th pulse, pi\n\
    d6                          ; delay before RVE\n\
    d0                          ; acquistion delay\n\
    acq [sg1]                   ; acquisition\n\
   next i                       ; end of accumulation loop\n\
   dx = dx + d30                ; create x axis\n\
   d13 = d13 + d30               ; increment d3\n\
   d15 = d15 - d30                ; constant time experiment\n\
  next x\n\
   d1=d1+d4                     ; increment tau1 for nucl. mod. averaging   \n\
   d8=d8+d4                     ; pump pulse delay must be incremented, too\n\
   d7=d7+d4\n\
  next j\n\
 scansdone(k)                   ; output of scans done\n\
 next k                         ; end of averaging loop\n\
\n\
end exp\n\
\n\
;\n\
begin exp1 "2D 5-Pulse RIDME RVE" [INTG QUAD lists lists2]\n\
; QUAD detection Single Point - 4-step phase cycle default\n\
\n\
  \n\
d8 = d3                         ; store initial d3\n\
d7 = d5                         ; store initial d5\n\
\n\
\n\
for y=1 to sy                   ; collect each spectrum for phasing\n\
\n\
\n\
  d3 = d8                       ; reset initial d3\n\
  d5 = d7                       ; reset initial d5\n\
  d11 = d5 - d1                 ;\n\
  d6 = d11 + d3                 ; define d6\n\
  dx = d3 - d1                  ; reset initial x\n\
  \n\
  sweep x=1 to sx               ; tau sweep loop\n\
    shot i=1 to h                     ; accumulation loop\n\
    d9                          ; DAF (Delay After Flash)\n\
    p0 [awg0]                    ; 1st pulse, pi/2\n\
    d1                          ; tau\n\
    p1 [awg1]                    ; 2nd pulse, pi\n\
    d3                          ; initial delay, 40 ns less than tau\n\
    p0 [awg2]                    ; 3rd pulse, pi/2 and phase program\n\
    d2                          ; Constant time T, ~30us?\n\
    p0 [awg2]                    ; 4th pulse, pi/2\n\
    d5                          ; make longer than total aquisition\n\
    p1 [awg1]                    ; 5th pulse, pi\n\
    d6                          ; delay before RVE\n\
    d0                          ; acquistion delay\n\
    acq [sg1]                   ; acquisition\n\
   next i                            ; end of accumulation loop\n\
   dx = dx + d30                ; create x axis\n\
   d3 = d3 + d30                ; increment d3\n\
   d5 = d5 - d30                ; constant time experiment\n\
  next x\n\
 \n\
 next y                             ; end of averaging loop\n\
\n\
end exp1\n\
\n\
begin exp2 "5P RIDME RSE" [INTG QUAD lists lists2]\n\
; QUAD detection Single Point - 4-step phase cycle default\n\
\n\
d8 = d3                         ; store initial d3\n\
\n\
d11 = d5  + d1                  ;\n\
d7  = d11 - d3                  ; define d7, initial d6\n\
\n\
 for k=1 to n                   ; averaging loop\n\
  totscans(n)                   ; output of total number of scans\n\
\n\
  d3 = d8                       ; reset initial d3\n\
  d6 = d7                       ; reset initial d6\n\
  dx = d3 - d1                  ; reset initial x\n\
  \n\
  sweep x=1 to sx               ; tau sweep loop\n\
\n\
   shot i=1 to h                     ; accumulation loop\n\
    d9                          ; DAF (Delay After Flash)\n\
    p0 [awg0]                    ; 1st pulse, pi/2\n\
    d1                          ; tau\n\
    p1 [awg1]                    ; 2nd pulse, pi\n\
    d3                          ; initial delay, 40 ns less than tau\n\
    p0 [awg2]                    ; 3rd pulse, pi/2 and phase program\n\
    d2                          ; Constant time T, ~30us?\n\
    p0 [awg2]                    ; 4th pulse, pi/2\n\
    d5                          ; make longer than total aquisition\n\
    p1 [awg1]                    ; 5th pulse, pi\n\
    d6                          ; delay before RVE\n\
    d0                          ; acquistion delay\n\
    acq [sg1]                   ; acquisition\n\
   next i                            ; end of accumulation loop\n\
\n\
   dx = dx + d30                ; create x axis\n\
   d3 = d3 + d30                ; increment d3\n\
   d6 = d6 - d30                ; constant time experiment\n\
  next x\n\
  \n\
 scansdone(k)                   ; output of scans done\n\
 next k                         ; end of averaging loop\n\
\n\
end exp2\n\
\n\
begin exp3 "5P RIDME RVE vs Tr" [INTG QUAD lists lists2 lists3]\n\
; QUAD detection Single Point - 4-step phase cycle default\n\
\n\
d8 = d3                         ; store initial d3\n\
d7 = d5                         ; store initial d5\n\
d20= d2                         ; store initial d2\n\
d21= d1                         ; store initial d2\n\
for k=1 to n                    ; averaging loop\n\
  totscans(n)                   ; output of total number of scans\n\
  d2=d20                        ; reset initial d2\n\
for y=1 to sy                   ; number of Tr wait times\n\
\n\
d8=d3                           ; initial delay between second observer\n\
d7=d5                         ; pulse and pump pulse\n\
d1=d21                          ; initial tau1 value\n\
for j=1 to m                    ; tau1 averaging loop for suppression of\n\
;                                nuclear modulations\n\
  d13 = d8                       ; reset initial d3\n\
  d15 = d7                       ; reset initial d5\n\
  d11 = d15 - d1                 ;\n\
  d6 = d11 + d13                 ; define d6\n\
  dx = d13 - d1                  ; reset initial x\n\
  \n\
  sweep x=1 to sx               ; tau sweep loop\n\
    shot i=1 to h                     ; accumulation loop\n\
    d9                          ; DAF (Delay After Flash)\n\
    p0 [awg3]                    ; 1st pulse, pi/2\n\
    d1                          ; tau\n\
    p1 [awg4]                    ; 2nd pulse, pi\n\
    d13                          ; initial delay, 40 ns less than tau\n\
    p0 [awg5]                    ; 3rd pulse, pi/2 and phase program\n\
    d2                          ; Constant time T, ~30us?\n\
    p0 [awg5]                    ; 4th pulse, pi/2\n\
    d15                          ; make longer than total aquisition\n\
    p1 [awg4]                    ; 5th pulse, pi\n\
    d6                          ; delay before RVE\n\
    d0                          ; acquistion delay\n\
    acq [sg1]                   ; acquisition\n\
   next i                            ; end of accumulation loop\n\
   dx = dx + d30                ; create x axis\n\
   d13 = d13 + d30                ; increment d3\n\
   d15 = d15 - d30                ; constant time experiment\n\
  next x\n\
   d1=d1+d4                     ; increment tau1 for nucl. mod. averaging   \n\
   d8=d8+d4                     ; pump pulse delay must be incremented, too\n\
   d7=d7+d4  \n\
  next j\n\
d2 = d2 + d31\n\
 \n\
next y                             ; end of averaging loop\n\
  scansdone(k)                   ; output of scans done                  \n\
  next k                         ; end of averaging loop\n\
end exp3\n\
\n\
begin exp4 "5P RIDME RVE vs B0" [INTG QUAD lists lists2 lists3]\n\
; QUAD detection Single Point - 4-step phase cycle default\n\
\n\
d8 = d3                         ; store initial d3\n\
d7 = d5                         ; store initial d5\n\
d21= d1\n\
for k=1 to n                    ; averaging loop\n\
  totscans(n)                   ; output of total number of scans\n\
bsweep y=1 to sy                   ; number of Tr wait times\n\
d8=d3                           ; initial delay between second observer\n\
d7=d5                              ; pulse and pump pulse\n\
d1=d21                          ; initial tau1 value\n\
for j=1 to m                    ; tau1 averaging loop for suppression of\n\
;                                nuclear modulations\n\
  d13 = d8                       ; reset initial d3\n\
  d15 = d7                       ; reset initial d5\n\
  d11 = d15 - d1                 ;\n\
  d6 = d11 + d13                 ; define d6\n\
  dx = d13 - d1                  ; reset initial x\n\
  \n\
  sweep x=1 to sx               ; tau sweep loop\n\
    shot i=1 to h                     ; accumulation loop\n\
    d9                          ; DAF (Delay After Flash)\n\
    p0 [awg3]                    ; 1st pulse, pi/2\n\
    d1                          ; tau\n\
    p1 [awg4]                    ; 2nd pulse, pi\n\
    d13                          ; initial delay, 40 ns less than tau\n\
    p0 [awg5]                    ; 3rd pulse, pi/2 and phase program\n\
    d2                          ; Constant time T, ~30us?\n\
    p0 [awg5]                    ; 4th pulse, pi/2\n\
    d15                          ; make longer than total aquisition\n\
    p1 [awg4]                    ; 5th pulse, pi\n\
    d6                          ; delay before RVE\n\
    d0                          ; acquistion delay\n\
    acq [sg1]                   ; acquisition\n\
   next i                            ; end of accumulation loop\n\
   dx = dx + d30                ; create x axis\n\
   d13 = d13 + d30                ; increment d3\n\
   d15 = d15 - d30                ; constant time experiment\n\
  next x\n\
   d1=d1+d4                     ; increment tau1 for nucl. mod. averaging   \n\
   d8=d8+d4                     ; pump pulse delay must be incremented, too\n\
   d7=d7+d4\n\
  next j\n\
next y                             ; end of averaging loop\n\
  scansdone(k)                   ; output of scans done                  \n\
  next k                         ; end of averaging loop\n\
end exp4\n\
\n\
begin exp5 "5P CIDME RVE" [INTG QUAD lists lists2 lists3]\n\
; QUAD detection Single Point - 4-step phase cycle default\n\
\n\
d8 = d3                         ; store initial d3\n\
d7 = d5                         ; store initial d5\n\
d21 = d1                         ; store initial tau1 value\n\
 for k=1 to n                   ; averaging loop\n\
  totscans(n)                   ; output of total number of scans\n\
d8=d3                           ; initial delay between second observer\n\
d7=d5                           ; pulse and pump pulse\n\
d1=d21                          ; initial tau1 value\n\
for j=1 to m                    ; tau1 averaging loop for suppression of\n\
;                                nuclear modulations\n\
  d13 = d8                      ; reset initial d3\n\
  d15 = d7                      ; reset initial d5\n\
  d11 = d15 - d1               ;\n\
  d6 = d11 + d13                ; define d6\n\
  dx = d13 - d1                ; reset initial x\n\
  \n\
  sweep x=1 to sx               ; tau sweep loop\n\
    shot i=1 to h               ; accumulation loop\n\
    d9                          ; DAF (Delay After Flash)\n\
    p0 [awg3]                   ; 1st pulse, pi/2\n\
    d1                          ; tau\n\
    p1 [awg4]                   ; 2nd pulse, pi\n\
    d13                         ; initial delay, 40 ns less than tau\n\
    p0 [awg5]                   ; 3rd pulse, pi/2 and phase program\n\
    d10                          ; Constant time T, ~5us, 10us total\n\
    p2 [awg6]                   ; 4th pulse, pi/2\n\
    d16                          ; Constant time T, ~5us, 10us total\n\
    p0 [awg5]                   ; 4th pulse, pi/2\n\
    d15                          ; make longer than total aquisition\n\
    p1 [awg4]                   ; 5th pulse, pi\n\
    d6                          ; delay before RVE\n\
    d0                          ; acquistion delay\n\
    acq [sg1]                   ; acquisition\n\
   next i                       ; end of accumulation loop\n\
   dx = dx + d30                ; create x axis\n\
   d13 = d13 + d30               ; increment d3\n\
   d15 = d15 - d30                ; constant time experiment\n\
  next x\n\
   d1=d1+d4                     ; increment tau1 for nucl. mod. averaging   \n\
   d8=d8+d4                     ; pump pulse delay must be incremented, too\n\
   d7=d7+d4\n\
  next j\n\
 scansdone(k)                   ; output of scans done\n\
 next k                         ; end of averaging loop\n\
\n\
end exp5\n\
\n\
\n
